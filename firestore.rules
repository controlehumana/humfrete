rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dados do dashboard — leitura apenas para autenticados
    match /dados/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // apenas via SDK Admin (processar_frete.py)
    }

    // Perfis de usuario
    match /users/{uid} {
      // Leitura: proprio usuario ou admin
      allow read: if request.auth.uid == uid
                  || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;

      // Criacao pelo proprio usuario — sem poder se tornar admin
      allow create: if request.auth.uid == uid
                    && !('isAdmin' in request.resource.data);

      // Atualizacao pelo proprio usuario — nao pode alterar isAdmin nem empresas/tabs
      allow update: if request.auth.uid == uid
                    && request.resource.data.isAdmin == resource.data.isAdmin
                    && request.resource.data.empresas == resource.data.empresas
                    && request.resource.data.tabs == resource.data.tabs;

      // Admin pode criar/atualizar qualquer usuario
      allow create, update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;

      // Ninguem deleta usuarios pela regra (apenas via Console ou SDK Admin)
      allow delete: if false;
    }
  }
}
